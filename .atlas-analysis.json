  "keyFeatures": [
    "8 optimized Islamic translation prompts (Hadith, Fiqh, Tafsir, etc.) with strongly-typed access",
    "Comprehensive LLM output validation catching hallucinations, formatting errors, and Arabic script leaks",
    "Automatic prompt stacking combining master prompts with specialized addons",
    "Precise error ranges with start/end indices for highlighting translation issues",
    "Automated fixers for common LLM formatting mistakes like collapsed speaker labels",
    "Gold standard reference dataset for benchmarking translation quality",
    "ALA-LC transliteration standard support with diacritic handling",
    "Zero dependencies runtime with TypeScript types included"
  ],
  "publicApiSurface": [
    "getPrompt(id: PromptId): StackedPrompt",
    "getPrompts(): StackedPrompt[]",
    "getStackedPrompt(id: PromptId): string",
    "getMasterPrompt(): string",
    "getPromptIds(): PromptId[]",
    "stackPrompts(master: string, addon: string): string",
    "validateTranslationResponse(segments: Segment[], response: string, options?: ValidationOptions): ValidationResponseResult",
    "formatExcerptsForPrompt(segments: Segment[], prompt: string): string",
    "normalizeTranslationText(text: string): string",
    "normalizeTranslationTextWithMap(text: string): { normalized: string; indexMap: number[] }",
    "extractTranslationIds(text: string): string[]",
    "parseTranslations(response: string): Map<string, string>",
    "parseTranslationsInOrder(response: string): Array<{ id: string; text: string }>",
    "fixCollapsedSpeakerLines(text: string, config?: FixConfig): FixResult",
    "fixAll(text: string, options: FixAllOptions): FixResult",
    "VALIDATION_ERROR_TYPE_INFO: Record<ValidationErrorType, { description: string }>"
  ]
